{
  "mcpServers": {
    "phoenix": {
      "command": "npx",
      "args": ["-y", "@arizeai/phoenix-mcp@latest"],
      "env": {
        "PHOENIX_API_KEY": "${PHOENIX_API_KEY}",
        "PHOENIX_BASE_URL": "${PHOENIX_BASE_URL}"
      }
    },
    "market-fit-ledger": {
      "command": "python",
      "args": ["mcp/ledger_server.py"],
      "env": {
        "LEDGER_STORE_PATH": ".local/ledger_store.json"
      }
    }
  }
}

