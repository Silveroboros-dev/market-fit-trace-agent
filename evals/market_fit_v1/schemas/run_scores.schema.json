{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-ledger.local/schemas/market_fit_v1/run_scores.schema.json",
  "title": "Market Fit Run Scores",
  "type": "object",
  "additionalProperties": true,
  "required": ["eval_version", "total_expected", "total_outputs", "metrics"],
  "properties": {
    "run_id": { "type": "string" },
    "eval_version": { "type": "string" },
    "total_expected": { "type": "integer" },
    "total_outputs": { "type": "integer" },
    "metrics": { "type": "object" },
    "regressions": { "type": "array" }
  }
}
