# Google ADK / Gemini
GOOGLE_ADK_ENABLED=true
GOOGLE_API_KEY=your-google-ai-studio-key-if-using-api-key-auth
GEMINI_MODEL=gemini-3.5-flash

# Optional Google Cloud Vertex AI Gemini / ADK Cloud Run deployment.
# GOOGLE_CLOUD_LOCATION is the Gemini model endpoint location. Keep Cloud Run
# deployment region separate in CLOUD_RUN_REGION.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
CLOUD_RUN_REGION=us-central1

# Phoenix / OpenInference
PHOENIX_PROJECT_NAME=market_fit_trace_agent
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_ISOLATED_TRACER_PROVIDER=false

# Cloud Run ADK deployment
SERVICE_NAME=market-fit-trace-agent-adk
ADK_AGENT_PATH=market_fit_adk
# Optional Secret Manager secret name for Cloud Run, preferred over direct key env deploy.
PHOENIX_API_KEY_SECRET=phoenix-api-key

# Optional Phoenix MCP direct operations
PHOENIX_MCP_ENABLED=false
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_ARGS=-y,@arizeai/phoenix-mcp@latest

# App
LEDGER_STORE_PATH=.local/ledger_store.json
MARKET_DATA_PATH=app/data/seed_markets.json
